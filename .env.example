# ╔══════════════════════════════════════════════════════════╗
# ║  ENCLAVE CONFIGURATION                                  ║
# ║  Copy to .env and fill in your values                   ║
# ╚══════════════════════════════════════════════════════════╝

# ── AI Providers ─────────────────────────────────────────────
# LLM (text generation): "ollama" | "openai" | "anthropic"
LLM_PROVIDER=ollama

# Embedding: "ollama" | "openai"
# Anthropic has no embedding API — use ollama or openai for embeddings
# regardless of which LLM you choose.
EMBEDDING_PROVIDER=ollama

# Embedding vector dimension — must match the model below.
# nomic-embed-text = 768 | text-embedding-3-small = 1536
# WARNING: changing EMBEDDING_PROVIDER or EMBEDDING_DIMENSION after documents
# have been ingested requires a full DB wipe + complete re-ingest.
# Mixed-dimension vectors will crash PostgreSQL.
EMBEDDING_DIMENSION=768

# Ollama
OLLAMA_HOST=http://ollama:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_GEN_MODEL=llama3.2:3b
OLLAMA_NUM_CTX=4096
OLLAMA_TIMEOUT_SECONDS=120

# OpenAI
OPENAI_API_KEY=
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_GEN_MODEL=gpt-4o-mini

# Anthropic (generation only — no embedding support)
ANTHROPIC_API_KEY=
ANTHROPIC_GEN_MODEL=claude-sonnet-4-6

# ── Database ────────────────────────────────────────────────
# Options: "local" | "cloud"
DB_PROVIDER=local

# Local PostgreSQL (used when DB_PROVIDER=local)
POSTGRES_USER=enclave
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=enclave
DATABASE_URL=postgresql+asyncpg://enclave:CHANGE_ME@db:5432/enclave

# Cloud PostgreSQL (used when DB_PROVIDER=cloud)
# DATABASE_URL=postgresql+asyncpg://user:pass@cloud-host:5432/enclave

# ── Security ────────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_TO_RANDOM_64_CHAR_STRING_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
JWT_ACCESS_EXPIRY_HOURS=24
JWT_REFRESH_EXPIRY_DAYS=30

# ── Application ─────────────────────────────────────────────
APP_NAME=Enclave
CORS_ORIGINS=http://localhost:3000
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ── Session Management ──────────────────────────────────────
SESSION_TTL_DAYS=30
SESSION_PURGE_CRON=0 2 * * *

# ── Document Editor ─────────────────────────────────────────
# Set to true only on hardware with 16GB+ RAM (ONLYOFFICE needs ~4GB).
# When false, the onlyoffice container does not start (compose profile "editor").
ENABLE_DOCUMENT_EDITOR=false
ONLYOFFICE_URL=http://onlyoffice:8443
ONLYOFFICE_JWT_SECRET=CHANGE_ME_ONLYOFFICE_SECRET

# ── System Admin (first boot only) ─────────────────────────
ADMIN_EMAIL=admin@enclave.local
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

# ── Ingestion ───────────────────────────────────────────────
MAX_FILE_SIZE_MB=50
SUPPORTED_FILE_TYPES=pdf,docx,md,txt,csv
CHUNK_SIZE_TOKENS=400
CHUNK_OVERLAP_TOKENS=50
